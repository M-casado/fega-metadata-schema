{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/M-casado/fega-metadata-schema/main/schemas/entities/protocol/schema.json",
  "type": "object",
  "title": "EGA protocol metadata schema",
  "meta:version": "0.0.0",
  "$async": true,
  "description": "Detailed plan of instructions on how a procedure is done. For example, sample preparation, sequencing or feature extraction techniques.",
  "@context": "./context.jsonld",
  "$comment": "Protocol parameters may be added in the future to compare expected parameters from the protocol with values provided by an executed process. Candidate models include the process parameters array, schema:StatisticalVariable, and schema:PropertyValue.",
  "meta:sssomMappings": [
    {
      "predicate_id": "skos:broadMatch",
      "object_id": "dct:provenance",
      "mapping_justification": "semapv:ManualMappingCuration",
      "object_match_field": "rdfs:comment",
      "subject_match_field": "rdfs:comment",
      "author_id": ["orcid:0000-0002-7747-6256"],
      "creator_id": ["orcid:0000-0002-7747-6256"],
      "reviewer_id": [""],
      "confidence": 1.0,
      "mapping_date": "2026-03-12",
      "$comment": "A HealthDCAT-AP (release 6) 'dct:provenance' property of a Dataset captures in an rather vague way the information that the EGA protocol metadata schema is intended to contain. Thus, the former can be produced by aggregating the protocols used to obtain datafiles included in a dataset."
    }
  ],
  "allOf": [
    {
      "title": "Base constraints for JSON-LD",
      "$ref": "../../../standards/json-schema/json-ld.org/FEGA.jsonld-schema.json"
    },
    {
        "title": "Entity type restriction",
        "$ref": "../../common/schema.json#/$defs/relationshipItemRestrictionProtocol"
    },
    {
      "title": "BioSchemas type requirement",
      "description": "A protocol must be typed as either a ComputationalWorkflow or a LabProtocol via BioSchemas, which also triggers compatibility validation against the respective BioSchemas profile.",
      "required": ["@type"],
      "properties": {
        "@type": {
          "type": "array",
          "anyOf": [
            { "contains": { "const": "bioschemastypes:ComputationalWorkflow" } },
            { "contains": { "const": "bioschemastypes:LabProtocol" } }
          ]
        }
      }
    },
    {
      "title": "Compatibility with BioSchemas ComputationalWorkflow",
      "if": {
        "required": ["@type"],
        "properties": {
          "@type": {
              "anyOf": [
                { "const": "bioschemastypes:ComputationalWorkflow" },
                { "type": "array",
                  "contains": { "const": "bioschemastypes:ComputationalWorkflow" } }
              ]
            }
        }
      },
      "then": {
        "$comment": "These BioSchemas files were fetched from BioSchemas API. See https://github.com/EGA-archive/fega-metadata-schema/issues/6 for more details.",
        "$ref": "https://raw.githubusercontent.com/M-casado/fega-metadata-schema/main/standards/json-schema/bioschemas/ComputationalWorkflow_v1.1-DRAFT.json"
      }
    },
    {
      "title": "Compatibility with BioSchemas LabProtocol",
      "if": {
        "required": ["@type"],
        "properties": {
          "@type": {
            "anyOf": [
              { "const": "bioschemastypes:LabProtocol" },
              { "type": "array",
                "contains": { "const": "bioschemastypes:LabProtocol" } }
            ]
          }
        }
      },
      "then": {
        "$comment": "These BioSchemas files were fetched from BioSchemas API. See https://github.com/EGA-archive/fega-metadata-schema/issues/6 for more details.",
        "$ref": "https://raw.githubusercontent.com/M-casado/fega-metadata-schema/main/standards/json-schema/bioschemas/LabProtocol_v0.8-DRAFT.json"
      }
    }
  ],
  "$defs": {
    "computingRequirements": {
      "type": "object",
      "properties": {
        "memory": {
          "type": "string",
          "description": "Minimum memory (RAM) requirements (e.g., '8GB', '16GB')",
          "meta:sssomMappings": [
              {
                  "predicate_id": "skos:exactMatch",
                  "object_id": "schema:memoryRequirements",
                  "mapping_justification": "semapv:ManualMappingCuration",
                  "object_match_field": "rdfs:comment",
                  "subject_match_field": "rdfs:comment",
                  "author_id": ["orcid:0000-0002-7747-6256"],
                  "creator_id": ["orcid:0000-0002-7747-6256"],
                  "reviewer_id": [""],
                  "confidence": 1.0,
                  "mapping_date": "2025-08-08"
              }
          ],
          "pattern": "^[0-9]+(GB|MB|TB)$",
          "examples": ["4GB", "16GB", "128GB"]
        },
        "cpuCores": {
          "type": "number",
          "description": "Number of CPU cores needed to run the workflow",
          "minimum": 1,
          "examples": [2, 4, 8]
        },
        "gpuAcceleration": {
          "type": "boolean",
          "description": "Whether GPU acceleration is required",
          "examples": [true, false]
        },
        "storage": {
          "type": "string", 
          "description": "Amount of disk space required (e.g., '100GB', '1TB')",
          "meta:sssomMappings": [
              {
                  "predicate_id": "skos:exactMatch",
                  "object_id": "schema:storageRequirements",
                  "mapping_justification": "semapv:ManualMappingCuration",
                  "object_match_field": "rdfs:comment",
                  "subject_match_field": "rdfs:comment",
                  "author_id": ["orcid:0000-0002-7747-6256"],
                  "creator_id": ["orcid:0000-0002-7747-6256"],
                  "reviewer_id": [""],
                  "confidence": 1.0,
                  "mapping_date": "2025-08-08"
              }
          ],
          "pattern": "^[0-9]+(GB|MB|TB)$",
          "examples": ["50GB", "500GB", "2TB"]
        }
      }
    }
  },
  "properties": {
    "@id": {
      "$ref": "../../common/schema.json#/$defs/@id"
    },

    "@type": {
        "title": "Protocol resource type",
        "description": "The JSON-LD type for an EGA protocol.",
        "allOf": [
            {
              "$comment": "We force this @type to be an array, which triggers the inherited 'relationshipItemRestrictionProtocol' validation of array. We don't let it be a string alone, because that would be ambiguous. The 'ega:protocol' type alone is just allowed for relationships pointing to an ega:protocol that may not need to be so explicit. That is not the case of the core @type of a protocol.",
              "type": "array"
            },
            { "$ref": "../../common/schema.json#/$defs/@type" }
        ],
        "examples": [
            ["ega:protocol", "prov:Plan", "bioschemastypes:labProtocol"],
            ["ega:protocol", "prov:Plan", "bioschemastypes:ComputationalWorkflow"]
        ]
    },

    "sameAs": {
      "allOf": [
        {
          "$ref": "../../common/schema.json#/$defs/sameAs"
        },
        {
          "items": {
            "title": "Entity type restriction",
            "$ref": "../../common/schema.json#/$defs/relationshipItemRestrictionProtocol"
          }
        }
      ]
    },

    "isBasedOn": {
      "$ref": "../../common/schema.json#/$defs/isBasedOn",
      "$comment": "This is used when the protocol that it's referenced is not exactly the same: this protocol was a modification of the original one, or it was used as a base to create this protocol. E.g., changed parameters, or added new steps.",
      "meta:sssomMappings": [
        {
          "predicate_id": "skos:narrowMatch",
          "object_id": "https://datacite-metadata-schema.readthedocs.io/en/4.5/appendices/appendix-1/relationType/#isnewversionof",
          "mapping_justification": "semapv:ManualMappingCuration",
          "object_match_field": "rdfs:comment",
          "subject_match_field": "rdfs:comment",
          "author_id": ["orcid:0000-0002-7747-6256"],
          "creator_id": ["orcid:0000-0002-7747-6256"],
          "reviewer_id": [""],
          "confidence": 1.0,
          "mapping_date": "2025-08-08"
        }
      ]
    },

    "version": {
      "$ref": "https://raw.githubusercontent.com/M-casado/fega-metadata-schema/main/standards/json-schema/bioschemas/ComputationalWorkflow_v1.1-DRAFT.json#/properties/version"
    }
  }
}
