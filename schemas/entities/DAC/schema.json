  "$defs": {
    "contactPoint": {
      "type": "object",
      "title": "DAC contact point",
      "description": "A contact point for DAC enquiries. Email is the principal contact method for a DAC.",
      "required": ["@type", "email"],
      "properties": {
        "@id": {
          "$ref": "../../common/schema.json#/$defs/@id",
          "examples": [
            "ega:EGAC00000000001#contact-point-1",
            "https://example.org/contact-points/example-dac"
          ]
        },
        "@type": {
          "anyOf": [
            {
              "const": "cv:ContactPoint"
            },
            {
              "type": "array",
              "minItems": 2,
              "uniqueItems": true,
              "contains": {
                "const": "cv:ContactPoint"
              }
            }
          ],
          "examples": [
            "cv:ContactPoint",
            ["cv:ContactPoint", "vcard:Kind"]
          ]
        },
        "email": {
          "type": "string",
          "title": "Contact email",
          "description": "An email address for DAC enquiries.",
          "format": "email",
          "examples": [
            "dac@example.org",
            "data-access@example.org"
          ]
        },
        "telephone": {
          "type": "string",
          "title": "Contact telephone number",
          "description": "A telephone number for DAC enquiries in E.164 format.",
          "pattern": "^\\+[1-9][0-9]{1,14}$",
          "examples": [
            "+442012345678",
            "+15551234567"
          ]
        },
        "contactPage": {
          "title": "Contact page",
          "description": "An optional web page with further DAC contact information.",
          "allOf": [
            {
              "$ref": "../../common/schema.json#/$defs/externalIdentifier"
            }
          ],
          "examples": [
            "https://example.org/contact/data-access",
            "https://example.org/dac/help"
          ]
        }
      },
      "examples": [
        {
          "@id": "ega:EGAC00000000001#contact-point-1",
          "@type": "cv:ContactPoint",
          "email": "dac@example.org",
          "telephone": "+442012345678"
        },
        {
          "@type": ["cv:ContactPoint", "vcard:Kind"],
          "email": "access@example.org",
          "contactPage": "https://example.org/contact/data-access"
        }
      ]
    },

    "component": {
      "type": "object",
      "title": "DAC component membership",
      "description": "A membership that relates an agent to the DAC and states the roles that agent performs.",
      "required": ["@type", "agent", "roles"],
      "properties": {
        "@id": {
          "$ref": "../../common/schema.json#/$defs/@id",
          "examples": [
            "ega:EGAC00000000001#membership-1",
            "urn:uuid:bd08aa08-47ac-412d-b978-68660c23928e"
          ]
        },
        "@type": {
          "anyOf": [
            {
              "const": "org:Membership"
            },
            {
              "type": "array",
              "minItems": 2,
              "uniqueItems": true,
              "contains": {
                "const": "org:Membership"
              }
            }
          ],
          "examples": [
            "org:Membership",
            ["org:Membership", "prov:Association"]
          ]
        },
        "agent": {
          "title": "Component agent",
          "description": "The participating person, organisation or other agent.",
          "$ref": "#/$defs/componentAgent",
          "meta:sssomMappings": [
            {
              "predicate_id": "skos:closeMatch",
              "object_id": "org:member",
              "mapping_justification": "semapv:ManualMappingCuration",
              "object_match_field": "rdfs:comment",
              "subject_match_field": "rdfs:comment",
              "author_id": ["orcid:0000-0002-7747-6256"],
              "creator_id": ["orcid:0000-0002-7747-6256"],
              "reviewer_id": [""],
              "confidence": 1.0,
              "mapping_date": "2026-07-21"
            },
            {
              "predicate_id": "skos:closeMatch",
              "object_id": "schema:member",
              "mapping_justification": "semapv:ManualMappingCuration",
              "object_match_field": "rdfs:comment",
              "subject_match_field": "rdfs:comment",
              "author_id": ["orcid:0000-0002-7747-6256"],
              "creator_id": ["orcid:0000-0002-7747-6256"],
              "reviewer_id": [""],
              "confidence": 1.0,
              "mapping_date": "2026-07-21"
            }
          ],
          "examples": [
            {
              "@type": ["prov:Agent", "prov:Person"],
              "name": "Jane Doe"
            },
            {
              "@type": ["prov:Agent", "prov:Organization"],
              "name": "Example University"
            }
          ]
        },
        "agentType": {
          "title": "Agent classification",
          "description": "An optional concept classifying the nature of the agent, for example an EHDS Health Data Access Body. Structural classes belong in '@type'.",
          "allOf": [
            {
              "$ref": "../../common/schema.json#/$defs/externalIdentifier"
            }
          ],
          "meta:sssomMappings": [
            {
              "predicate_id": "skos:exactMatch",
              "object_id": "dct:type",
              "mapping_justification": "semapv:ManualMappingCuration",
              "object_match_field": "rdfs:label",
              "subject_match_field": "rdfs:label",
              "match_string": "agentType",
              "author_id": ["orcid:0000-0002-7747-6256"],
              "creator_id": ["orcid:0000-0002-7747-6256"],
              "reviewer_id": [""],
              "confidence": 1.0,
              "mapping_date": "2026-07-21"
            }
          ],
          "examples": [
            "eu-ehds:HealthDataAccessBody",
            "https://w3id.org/dpv/legal/eu/ehds#HealthDataHolder"
          ]
        },
        "roles": {
          "type": "array",
          "title": "DAC roles",
          "description": "Roles the agent performs in the DAC membership.",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "administrator",
              "member",
              "reviewer",
              "approver",
              "main_contact"
            ],
            "examples": [
              "administrator",
              "main_contact"
            ]
          },
          "meta:sssomMappings": [
            {
              "predicate_id": "skos:exactMatch",
              "object_id": "org:role",
              "mapping_justification": "semapv:ManualMappingCuration",
              "object_match_field": "rdfs:label",
              "subject_match_field": "rdfs:label",
              "match_string": "roles",
              "author_id": ["orcid:0000-0002-7747-6256"],
              "creator_id": ["orcid:0000-0002-7747-6256"],
              "reviewer_id": [""],
              "confidence": 1.0,
              "mapping_date": "2026-07-21"
            }
          ],
          "examples": [
            ["main_contact"],
            ["administrator", "approver"]
          ]
        }
      },
      "examples": [
        {
          "@id": "ega:EGAC00000000001#membership-1",
          "@type": "org:Membership",
          "agent": {
            "@type": ["prov:Agent", "prov:Person"],
            "name": "Jane Doe"
          },
          "roles": ["main_contact", "administrator"]
        },
        {
          "@type": "org:Membership",
          "agent": {
            "@type": ["prov:Agent", "prov:Organization"],
            "name": "Example University"
          },
          "agentType": "eu-ehds:HealthDataAccessBody",
          "roles": ["administrator"]
        }
      ]
    },

