{
    "@context": [
        "../../common/context.jsonld",
        {
            "entityDoc": "entities:dataset/schema.json#",
            "properties": "@nest"
        },
        {
            "id": {
              "@id": "dct:identifier"
            },
            "title": {
                "@id": "dct:title"
            },
            "alternativeTitle": {
                "@id": "dct:alternative",
                "@container": "@set"
            },
            "description": {
                "@id": "dct:description"
            },
            "documentation": {
                "@id": "foaf:page",
                "@type": "@id",
                "@container": "@set"
            },
            "landingPage": {
                "@id": "dcat:landingPage",
                "@type": "@id"
            },
            "isReferencedBy": {
                "@id": "dct:isReferencedBy",
                "@container": "@set"
            },
            "modificationDate": {
                "@id": "dct:modified",
                "@type": "http://www.w3.org/2001/XMLSchema#dateTime"
            },
            "datasetType": {
                "@id": "dct:type",
                "@container": "@set"
            },
            "hasPolicy": {
                "@id": "dct:hasPolicy",
                "@type": "@id"
            },
            "releaseDate": {
                "@id": "dct:issued",
                "@type": "http://www.w3.org/2001/XMLSchema#date"
            },
            "otherIdentifier": {
                "@id": "adms:identifier",
                "@container": "@set"
            },
            "populationCoverage": {
                "@id": "healthdcatap:populationCoverage"
            },
            "relatedResource": {
                "@id": "dct:relation",
                "@type": "@id",
                "@container": "@set"
            },
            "version": {
                "@id": "dcat:version"
            },
            "status": {
                "@id": "adms:status"
            },
            "dataUseConditions": {
                "@id": "ega:dataUseConditions",
                "@container": "@set"
            },
            "measurementTechnique": {
                "@id": "schema:measurementTechnique",
                "@container": "@set"
            },
            "variableMeasured": {
                "@id": "schema:variableMeasured",
                "@container": "@set"
            },
            "hasCodingSystem": {
                "@id": "entityDoc:hasCodingSystem",
                "@container": "@set"
            }
        }
    ]
}
