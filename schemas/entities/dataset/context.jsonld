{
    "@context": [
        "../../common/context.jsonld",
        {
            "entityDoc": "entities:dataset/schema.json#",
            "properties": "@nest"
        },
        {
            "id": {
              "@id": "dct:identifier",
              "@type": "string"
            },
            "title": {
                "@id": "dct:title",
                "@type": "langString"
            },
            "alternativeTitle": {
                "@id": "dct:alternative",
                "@type": "langString"
            },
            "description": {
                "@id": "dct:description",
                "@type": "langString"
            },
            "documentation": {
                "@id": "foaf:page",
                "@type": "@id"
            },
            "landingPage": {
                "@id": "dcat:landingPage",
                "@type": "@id"
            },
            "isReferencedBy": {
                "@id": "dct:isReferencedBy",
                "@type": "@id"
            },
            "modificationDate": {
                "@id": "dct:modified",
                "@type": "http://www.w3.org/2001/XMLSchema#dateTime"
            },
            "datasetType": {
                "@id": "dct:type",
                "@type": "@id"
            },
            "hasPolicy": {
                "@id": "dct:hasPolicy",
                "@type": "@id"
            },
            "releaseDate": {
                "@id": "dct:issued",
                "@type": "http://www.w3.org/2001/XMLSchema#date"
            },
            "otherIdentifiers": {
                "@id": "adms:identifier",
                "@type": "@id"
            },
            "populationCoverage": {
                "@id": "healthdcatap:populationCoverage",
                "@type": "langString"
            },
            "relatedResource": {
                "@id": "dct:relation",
                "@type": "@id"
            },
            "version": {
                "@id": "dcat:version",
                "@type": "string"
            },
            "status": {
                "@id": "adms:status",
                "@type": "string"
            },
            "dataUseConditions": {
                "@id": "ega:dataUseConditions"
            },
            "measurementTechnique": {
                "@id": "schema:measurementTechnique",
                "@type": "@id"
            },
            "variableMeasured": {
                "@id": "schema:variableMeasured",
                "@type": "@id"
            }
        }
    ]
}
