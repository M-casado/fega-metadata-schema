            "object_id": "healthdcatap:relatedResource",
            "mapping_justification": "semapv:ManualMappingCuration",
            "object_match_field": "rdfs:label",
            "subject_match_field": "rdfs:label",
            "author_id": ["orcid:0000-0002-7747-6256"],
            "creator_id": ["orcid:0000-0002-7747-6256"],
            "reviewer_id": [""],
            "confidence": 1.0,
            "mapping_date": "2026-07-22"
        },
        {
            "predicate_id": "skos:closeMatch",
            "object_id": "schema:citation",
            "mapping_justification": "semapv:ManualMappingCuration",
            "object_match_field": "rdfs:label",
            "subject_match_field": "rdfs:label",
            "author_id": ["orcid:0000-0002-7747-6256"],
            "creator_id": ["orcid:0000-0002-7747-6256"],
            "reviewer_id": [""],
            "confidence": 1.0,
            "mapping_date": "2026-07-22"
        },
        {
            "predicate_id": "skos:closeMatch",
            "object_id": "egav1ebi:EGA.dataset.xsd#DatasetType/DATASET_LINKS",
            "mapping_justification": "semapv:ManualMappingCuration",
            "object_match_field": "rdfs:label",
            "subject_match_field": "rdfs:label",
            "author_id": ["orcid:0000-0002-7747-6256"],
            "creator_id": ["orcid:0000-0002-7747-6256"],
            "reviewer_id": [""],
            "confidence": 1.0,
            "mapping_date": "2026-07-22"
        }
      ]
    },

    "version": {
      "title": "Policy version",
      "description": "The version indicator for this Policy entity.",
      "$comment": "Includes changes to any property of it, so if (e.g.) the policy text changes, it justifies a different version of the policy altogether.",
      "allOf": [
        { "$ref": "../../common/schema.json#/$defs/version" }
      ]
    },

    "validityPeriod": {
      "title": "Policy validity period",
      "description": "The optional period during which the policy is effective. At least one boundary (i.e., start or end) must be supplied.",
      "allOf": [
        {
          "$ref": "../../common/schema.json#/$defs/periodOfTime"
        }
      ],
      "examples": [
        {
          "@type": "dct:PeriodOfTime",
          "startDate": "2026-01-01T00:00:00Z",
          "endDate": "2028-12-31T23:59:59Z"
        }
      ]
    },

    "appliesTo": {
      "title": "Applicable datasets",
      "description": "Datasets governed by this policy.",
      "meta:sssomMappings": [
        {
          "predicate_id": "skos:relatedMatch",
          "object_id": "dct:rights",
          "mapping_justification": "semapv:ManualMappingCuration",
          "object_match_field": "rdfs:comment",
          "subject_match_field": "rdfs:comment",
          "author_id": ["orcid:0000-0002-7747-6256"],
          "creator_id": ["orcid:0000-0002-7747-6256"],
          "reviewer_id": [""],
          "confidence": 1.0,
          "mapping_date": "2026-07-22",
          "comment": "The mapping relation is 'reverse': 'appliesTo' is the reverse of 'dct:rights'."
        }
      ],
      "allOf": [
        { "$ref": "../../common/schema.json#/$defs/relationshipArray" },
        {
          "items": {
            "$ref": "../../common/schema.json#/$defs/relationshipItemRestrictionDataset"
          }
        }
      ],
      "examples": [
        [
          {
            "@id": "ega:EGAD00000000001",
            "@type": ["ega:dataset", "dcat:Dataset"]
          }
        ]
      ]
    },

    "sameAs": {
      "title": "Same as",
      "description": "External identifiers or resources representing the same policy.",
      "allOf": [
        { "$ref": "../../common/schema.json#/$defs/sameAs" }
      ]
    }
