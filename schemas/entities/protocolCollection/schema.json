      "$ref": "../../common/schema.json#/$defs/relationshipItemRestrictionProtocolCollection"
    }
  ],
  "properties": {
    "@id": {
      "$ref": "../../common/schema.json#/$defs/egaStableIdentifierProtocolCollection"
    },
    "@type": {
      "title": "Protocol collection resource type",
      "description": "The JSON-LD types for an EGA protocol collection.",
      "allOf": [
        {
          "$ref": "../../common/schema.json#/$defs/@type"
        }
      ]
