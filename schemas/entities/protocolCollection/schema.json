{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/M-casado/fega-metadata-schema/main/schemas/entities/protocolCollection/schema.json",
  "type": "object",
  "title": "EGA protocol collection metadata schema",
  "meta:version": "0.0.0",
  "$async": true,
  "description": "A versioned composite plan containing one or more reusable Protocol records. It represents the plan applied by a Process at the submitter-selected granularity.",
  "$comment": "Membership expresses inclusion only. We are not modelling the order of the steps, which could be done in the future if deemed worth it following the P-plan model. A collection may contain one protocol for a detailed Process or several protocols for a coarse Process.",
  "@context": "./context.jsonld",
  "required": ["@id", "@type", "title", "version", "hadMember"],
  "meta:sssomMappings": [
    {
      "predicate_id": "skos:narrowMatch",
      "object_id": "prov:Collection",
      "mapping_justification": "semapv:ManualMappingCuration",
      "object_match_field": "rdfs:comment",
      "subject_match_field": "rdfs:comment",
      "author_id": ["orcid:0000-0002-7747-6256"],
      "creator_id": ["orcid:0000-0002-7747-6256"],
      "reviewer_id": [""],
      "confidence": 1.0,
      "mapping_date": "2026-07-17"
    },
    {
      "predicate_id": "skos:narrowMatch",
      "object_id": "prov:Plan",
      "mapping_justification": "semapv:ManualMappingCuration",
      "object_match_field": "rdfs:comment",
      "subject_match_field": "rdfs:comment",
      "author_id": ["orcid:0000-0002-7747-6256"],
      "creator_id": ["orcid:0000-0002-7747-6256"],
      "reviewer_id": [""],
      "confidence": 1.0,
      "mapping_date": "2026-07-17"
    }
  ],
  "allOf": [
