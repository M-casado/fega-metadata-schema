{
  "@context": "https://raw.githubusercontent.com/M-casado/fega-metadata-schema/main/schemas/entities/biomaterial/schema.json",
  "@type": "ega:biomaterial",
  "@embed": "@always",
  "@explicit": false,

  "label": {},
  "biomaterialType": {},
  "description": {},
  "sex": {},
  "gender": {},
  "birthPlace": {},
  "dateOfBirth": {},
  "ethnicity": {},
  "ancestry": {},
  "diagnoses": {},
  "exposures": {},
  "interventionsOrProcedures": {},
  "measurements": {},
  "pedigrees": {},
  "phenotypicFeatures": {},
  "treatments": {},
  "timeAtLastEncounter": {},
  "taxonomy": {},
  "vitalStatus": {},
  "samplingSource": {},
  "collectionSite": {},
  "storageConditions": {},
  "samplingAge": {},
  "samplingDate": {},
  "samplingProcedure": {},

  "sameAs": [
    {
      "@embed": "@always"
    }
  ],
  "wasUsedBy": [
    {
      "@embed": "@always"
    }
  ],
  "wasGeneratedBy": [
    {
      "@embed": "@always"
    }
  ],
  "wasDerivedFrom": [
    {
      "@embed": "@always"
    }
  ]
}
