{
    "@context": {
        "id": "@id",
        "label": "rdfs:label",
        "name": "schema:name",
        "description": "schema:description",

        "schemas": "https://raw.githubusercontent.com/M-casado/fega-metadata-schema/main/schemas/",
        "entities": "schemas:entities/",
        "commonDefinitionsDoc": "schemas:common/schema.json#",
        "biomaterial": "entities:biomaterial/schema.json",
        "protocol": "entities:protocol/schema.json",
        "process": "entities:process/schema.json",
        "datafile": "entities:datafile/schema.json",
        "dataset": "entities:dataset/schema.json",
        "policy": "entities:policy/schema.json",
        "DAC": "entities:DAC/schema.json",
        "study": "entities:study/schema.json",
        "cohort": "entities:cohort/schema.json",
        "project": "entities:project/schema.json",
        "protocolCollection": "entities:protocolCollection/schema.json",

        "identifiers": "https://identifiers.org/",
        "ega": "identifiers:ega:",
        "prov": "https://www.w3.org/ns/prov#",
        "owl": "https://www.w3.org/2002/07/owl#",
        "skos": "https://www.w3.org/2009/08/skos-reference/skos.html#",
        "schema": "http://schema.org/",
        "bioschemastypes": "https://discovery.biothings.io/ns/bioschemas/bioschemas:",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "beaconRepo": "https://raw.githubusercontent.com/ga4gh-beacon/beacon-v2/v2.1.1/models/json/beacon-v2-default-model/",
        "dct": "http://purl.org/dc/terms/",
        "foaf": "http://xmlns.com/foaf/0.1/",
        "dpv": "https://w3id.org/dpv#",
        "adms": "http://www.w3.org/ns/adms#",
        "odrl": "https://www.w3.org/TR/odrl-vocab/#",
        "vcard": "http://www.w3.org/2006/vcard/ns#",
        "cv": "http://data.europa.eu/m8g/",

        "dcat": "http://www.w3.org/ns/dcat#",
        "dcatap": "http://data.europa.eu/r5r/",
        "healthdcatap": "http://healthdataportal.eu/ns/health#",

        "efo": "identifiers:efo:",
        "pato": "identifiers:PATO:",

        "egav1crg": "https://submission.ega-archive.org/api/spec/#/schemas/",
        "egav1ebi": "https://github.com/enasequence/webin-xml/master/src/main/resources/uk/ac/ebi/ena/sra/schema/",

        "sameAs": {
            "@id": "schema:sameAs",
            "@type": "@id",
            "@container": "@set"
        },
        "wasUsedBy": {
            "@reverse": "used",
            "@type": "@id",
            "@container": "@set"
        },
        "used": {
            "@id": "prov:used",
            "@type": "@id",
            "@container": "@set"
        },
        "wasGeneratedBy": {
            "@id": "prov:wasGeneratedBy",
            "@type": "@id",
            "@container": "@set"
        },
        "generated": {
            "@id": "prov:generated",
            "@type": "@id",
            "@container": "@set"
        },
        "wasDerivedFrom": {
            "@id": "prov:wasDerivedFrom",
            "@type": "@id",
            "@container": "@set"
        },
        "wasAttributedTo": {
            "@id": "prov:wasAttributedTo",
            "@type": "@id",
            "@container": "@set"
        },
        "actedOnBehalfOf": {
            "@id": "prov:actedOnBehalfOf",
            "@type": "@id",
            "@container": "@set"
        },
        "isPartOf": {
            "@id": "prov:isPartOf",
            "@type": "@id",
            "@container": "@set"
        },
        "hasPart": {
            "@reverse": "isPartOf",
            "@type": "@id",
            "@container": "@set"
        },
        "wasInformedBy": {
            "@id": "prov:wasInformedBy",
            "@type": "@id",
            "@container": "@set"
        },
        "informs": {
            "@reverse": "wasInformedBy",
            "@type": "@id",
            "@container": "@set"
        }
    }
}
