{
    "@context": {
        "id": "@id",
        "label": "rdfs:label",
        "name": "schema:name",
        "description": "schema:description",
        "identifier": "schema:identifier",
        "url": {
            "@id": "schema:url",
            "@type": "@id"
        },
        "affiliation": "schema:affiliation",
        "text": "schema:text",
        "fileFormat": "schema:encodingFormat",
        "modifiers": {
            "@id": "commonDefinitionsDoc:modifiers",
            "@container": "@set"
        },
        "causeOfDeath": "commonDefinitionsDoc:causeOfDeath",
        "evidence": {
            "@id": "commonDefinitionsDoc:evidence",
            "@container": "@set"
        },
        "excluded": "commonDefinitionsDoc:excluded",
        "familyHistory": "commonDefinitionsDoc:familyHistory",
        "negated": "commonDefinitionsDoc:negated",
        "occurrence": "commonDefinitionsDoc:occurrence",
        "onset": "commonDefinitionsDoc:onset",
        "proportion": "commonDefinitionsDoc:proportion",
        "referenceRange": "commonDefinitionsDoc:referenceRange",
        "route": "commonDefinitionsDoc:route",
        "severity": "commonDefinitionsDoc:severity",
        "stagingSystemVersion": "commonDefinitionsDoc:stagingSystemVersion",
        "survivalTimeInDays": "commonDefinitionsDoc:survivalTimeInDays",
        "timeOfDeath": "commonDefinitionsDoc:timeOfDeath",
        "tnmFindings": {
            "@id": "commonDefinitionsDoc:tnmFindings",
            "@container": "@set"
        },
        "tumorAttributes": "commonDefinitionsDoc:tumorAttributes",
        "tumorGrade": "commonDefinitionsDoc:tumorGrade",
        "tumorProgression": "commonDefinitionsDoc:tumorProgression",
        "tumorSize": {
            "@id": "commonDefinitionsDoc:tumorSize",
            "@container": "@set"
        },
        "type": "commonDefinitionsDoc:type",
        "unit": "commonDefinitionsDoc:unit",
        "value": "commonDefinitionsDoc:value",
        "givenName": "schema:givenName",
        "familyName": "schema:familyName",
        "email": "schema:email",

        "schemas": "https://raw.githubusercontent.com/M-casado/fega-metadata-schema/main/schemas/",
        "entities": "schemas:entities/",
        "commonDefinitionsDoc": "schemas:common/schema.json#",
        "biomaterial": "entities:biomaterial/schema.json",
        "protocol": "entities:protocol/schema.json",
        "process": "entities:process/schema.json",
        "datafile": "entities:datafile/schema.json",
        "dataset": "entities:dataset/schema.json",
        "policy": "entities:policy/schema.json",
        "DAC": "entities:DAC/schema.json",
        "study": "entities:study/schema.json",
        "cohort": "entities:cohort/schema.json",
        "project": "entities:project/schema.json",
        "protocolCollection": "entities:protocolCollection/schema.json",

        "identifiers": "https://identifiers.org/",
        "ega": "identifiers:ega:",
        "prov": "https://www.w3.org/ns/prov#",
        "owl": "https://www.w3.org/2002/07/owl#",
        "skos": "http://www.w3.org/2004/02/skos/core#",
        "schema": "http://schema.org/",
        "bioschemastypes": "https://discovery.biothings.io/ns/bioschemas/bioschemas:",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
